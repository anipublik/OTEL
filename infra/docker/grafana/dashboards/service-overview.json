{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "RED dashboard — Request rate, Error rate, Duration per service. Driven by OTEL semantic conventions.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Request Rate",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (service_name) (rate(otel_http_server_request_duration_seconds_count{service_name=~\"$service_name\", deployment_environment=~\"$environment\"}[5m]))",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "title": "Request Rate (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (service_name) (rate(otel_http_server_request_duration_seconds_count{service_name=~\"$service_name\", deployment_environment=~\"$environment\", http_response_status_code=~\"5..\"}[5m])) / sum by (service_name) (rate(otel_http_server_request_duration_seconds_count{service_name=~\"$service_name\", deployment_environment=~\"$environment\"}[5m]))",
          "legendFormat": "{{service_name}} error rate",
          "refId": "A"
        }
      ],
      "title": "Error Rate (5xx / total)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Request Duration",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
      "id": 3,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, sum by (le, service_name) (rate(otel_http_server_request_duration_seconds_bucket{service_name=~\"$service_name\", deployment_environment=~\"$environment\"}[5m])))",
          "legendFormat": "{{service_name}} p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (le, service_name) (rate(otel_http_server_request_duration_seconds_bucket{service_name=~\"$service_name\", deployment_environment=~\"$environment\"}[5m])))",
          "legendFormat": "{{service_name}} p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum by (le, service_name) (rate(otel_http_server_request_duration_seconds_bucket{service_name=~\"$service_name\", deployment_environment=~\"$environment\"}[5m])))",
          "legendFormat": "{{service_name}} p99",
          "refId": "C"
        }
      ],
      "title": "Request Duration — p50 / p95 / p99",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["otel-starter", "RED", "services"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Prometheus"
      },
      {
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(otel_http_server_request_duration_seconds_count, service_name)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "service_name",
        "query": {
          "query": "label_values(otel_http_server_request_duration_seconds_count, service_name)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "type": "query",
        "label": "Service"
      },
      {
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(otel_http_server_request_duration_seconds_count, deployment_environment)",
        "hide": 0,
        "includeAll": true,
        "multi": false,
        "name": "environment",
        "query": {
          "query": "label_values(otel_http_server_request_duration_seconds_count, deployment_environment)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "type": "query",
        "label": "Environment"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Service Overview — RED",
  "uid": "otel-service-overview",
  "version": 1
}
