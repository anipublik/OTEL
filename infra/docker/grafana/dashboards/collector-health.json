{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "annotations": { "list": [] },
  "description": "OTel Collector internal metrics: accepted/dropped spans, queue depth, memory. Look here first when telemetry stops flowing.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Ingest",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table" } },
      "targets": [
        {
          "expr": "rate(otelcol_receiver_accepted_spans_total[1m])",
          "legendFormat": "accepted spans/s",
          "refId": "A"
        },
        {
          "expr": "rate(otelcol_receiver_refused_spans_total[1m])",
          "legendFormat": "refused spans/s",
          "refId": "B"
        }
      ],
      "title": "Spans — Accepted vs Refused /s",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "rate(otelcol_receiver_accepted_metric_points_total[1m])",
          "legendFormat": "accepted metric points/s",
          "refId": "A"
        },
        {
          "expr": "rate(otelcol_receiver_refused_metric_points_total[1m])",
          "legendFormat": "refused metric points/s",
          "refId": "B"
        }
      ],
      "title": "Metric Points — Accepted vs Refused /s",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "targets": [
        {
          "expr": "rate(otelcol_receiver_accepted_log_records_total[1m])",
          "legendFormat": "accepted log records/s",
          "refId": "A"
        },
        {
          "expr": "rate(otelcol_receiver_refused_log_records_total[1m])",
          "legendFormat": "refused log records/s",
          "refId": "B"
        }
      ],
      "title": "Log Records — Accepted vs Refused /s",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 },
      "id": 101,
      "title": "Export",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 9 },
      "id": 4,
      "targets": [
        {
          "expr": "rate(otelcol_exporter_sent_spans_total[1m])",
          "legendFormat": "sent spans/s — {{exporter}}",
          "refId": "A"
        },
        {
          "expr": "rate(otelcol_exporter_send_failed_spans_total[1m])",
          "legendFormat": "failed spans/s — {{exporter}}",
          "refId": "B"
        }
      ],
      "title": "Exporter — Spans Sent vs Failed /s",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 900 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 9 },
      "id": 5,
      "targets": [
        {
          "expr": "otelcol_exporter_queue_size",
          "legendFormat": "queue size — {{exporter}}",
          "refId": "A"
        },
        {
          "expr": "otelcol_exporter_queue_capacity",
          "legendFormat": "queue capacity — {{exporter}}",
          "refId": "B"
        }
      ],
      "title": "Exporter Queue Depth (size vs capacity)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 102,
      "title": "Process",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 17 },
      "id": 6,
      "targets": [
        {
          "expr": "otelcol_process_memory_rss",
          "legendFormat": "RSS",
          "refId": "A"
        },
        {
          "expr": "otelcol_process_runtime_heap_alloc_bytes",
          "legendFormat": "heap alloc",
          "refId": "B"
        }
      ],
      "title": "Collector Memory",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 17 },
      "id": 7,
      "targets": [
        {
          "expr": "otelcol_process_uptime",
          "legendFormat": "uptime (s)",
          "refId": "A"
        }
      ],
      "title": "Collector Uptime",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["otel-starter", "collector", "health"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Prometheus"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Collector Health",
  "uid": "otel-collector-health",
  "version": 1
}
